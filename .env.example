# Copy this file to .env and fill in the values before deploying.
# .env is gitignored and should never be committed.

# The public domain for the inventory system (used by Caddy for TLS)
DOMAIN=inventory.binaryheart.org

# Postgres superuser password (used by the db-migrate service to run migrations)
DB_PASSWORD=changeme

# Password for the api_user DB role (used by the backend at runtime)
API_USER_PASSWORD=changeme_api_user

# Password for the importer DB role (used by the one-time data import)
IMPORTER_PASSWORD=changeme_importer

# Secret used to sign JWTs — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=changeme_jwt_secret
