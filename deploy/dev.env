# Non-secret configuration for the DEV environment stack.
# Loaded (together with secrets/dev.env) when deploying dev.

# GHCR image repository prefix (lowercase owner/repo).
REGISTRY=ghcr.io/binaryheartus/inventory-system

# Localhost-only Postgres port for admin access (dev uses 5433 to avoid clashing
# with prod's 5432 on the shared box).
DB_HOST_PORT=5433

# Network alias Caddy uses to reach this environment's frontend.
FRONTEND_ALIAS=inventory-dev-frontend

# Flyway migration folders to scan (recursively), listed explicitly. Dev scans
# the SAME folders as prod (010-040 + callbacks) PLUS the dev-only seed (090,
# the developer/viewer accounts).
# NOTE: keep this on ONE line with no spaces after the commas (the folder names
# themselves contain spaces, which is fine — Flyway splits only on commas).
FLYWAY_LOCATIONS=filesystem:/flyway/sql/010 - Tracked,filesystem:/flyway/sql/020 - Untracked - Procedures & Functions,filesystem:/flyway/sql/030 - Untracked - Triggers,filesystem:/flyway/sql/040 - Untracked - Views,filesystem:/flyway/sql/callbacks,filesystem:/flyway/sql/090 - Dev Only - Tracked

# Flyway validation leniency for the SHARED dev DB. Because different feature
# branches take turns deploying to the same dev database, one branch can leave
# behind repeatable migrations (stored procs / functions / views) that a later
# branch doesn't have, which makes `flyway validate` fail with "applied
# migration not resolved locally". Tolerating `repeatable:missing` on dev lets
# any branch deploy for testing; the leftover objects are harmless and each
# branch re-applies its own repeatables on migrate. `*:pending` is kept (it is
# required so the plan stage's validate doesn't fail on legit pending scripts).
# Prod does NOT set this, so it stays strict (compose defaults to `*:pending`).
FLYWAY_IGNORE_MIGRATION_PATTERNS=*:pending,repeatable:missing
