# Non-secret configuration for the PROD environment stack.
# Loaded (together with secrets/prod.env) when deploying prod.

# GHCR image repository prefix (lowercase owner/repo).
REGISTRY=ghcr.io/binaryheartus/inventory-system

# Localhost-only Postgres port for admin access.
DB_HOST_PORT=5432

# Network alias Caddy uses to reach this environment's frontend.
FRONTEND_ALIAS=inventory-prod-frontend

# Flyway migration folders to scan (recursively), listed explicitly. Prod scans
# the shared schema (010-040) and the callbacks, but NEVER the dev-only seed
# (090), so the developer/viewer accounts never reach production.
# NOTE: keep this on ONE line with no spaces after the commas (the folder names
# themselves contain spaces, which is fine — Flyway splits only on commas).
FLYWAY_LOCATIONS=filesystem:/flyway/sql/010 - Tracked,filesystem:/flyway/sql/020 - Untracked - Procedures & Functions,filesystem:/flyway/sql/030 - Untracked - Triggers,filesystem:/flyway/sql/040 - Untracked - Views,filesystem:/flyway/sql/callbacks
