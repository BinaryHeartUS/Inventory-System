# Reference for the per-environment SECRETS the stack needs. Do NOT commit real
# values.
#
# RECOMMENDED: store these as GitHub *Environment* secrets (one set per
# `development` / `production` environment) and run the "Sync Secrets" workflow to
# write secrets/<env>.env onto the server. GitHub is then the source of truth and
# rotation is: update the secret -> run Sync Secrets.
#
# MANUAL FALLBACK: create the file directly on the server (gitignored):
#   secrets/dev.env   and   secrets/prod.env
#
# Generate strong values, e.g.:
#   DB_PASSWORD=$(openssl rand -hex 24)
#   JWT_SECRET=$(openssl rand -hex 32)

# Postgres superuser (binaryheart) password.
DB_PASSWORD=

# Password for the api_user DB role used by the backend at runtime.
API_USER_PASSWORD=

# Password for the importer DB role (only used by the one-time data import).
IMPORTER_PASSWORD=

# Secret used to sign JWTs (use a long random string).
JWT_SECRET=
